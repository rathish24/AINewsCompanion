' App 1 sequence diagram — edit this file and re-render to regenerate sequence-diagram.png
' Render: PlantUML (CLI: plantuml sequence-diagram.puml) or use IDE/online PlantUML viewer
'
@startuml App1_Sequence
!theme plain
title App 1 — AI Companion flow (cache, conversation.json, topics.json, Bedrock)

actor User
participant "App\n(Sheet)" as App
participant "Cache\n(SwiftData)" as Cache
participant "Article\nFetcher" as Fetcher
participant "SwiftSoup\n(3rd party)" as SwiftSoup
participant "Conversation\nEngine" as Engine
participant "AWS Bedrock\n(3rd party)" as Bedrock
participant "Topic\nValidator" as Validator

User -> App: tap AI Companion (article URL)
App -> Cache: cachedResult(for: url)

alt cache hit
  Cache --> App: return cached CompanionResult
  App --> User: display summary (sheet)
else cache miss
  Cache --> App: nil

  App -> Fetcher: fetch(url)
  Fetcher -> SwiftSoup: parse HTML
  SwiftSoup --> Fetcher: plain text (ArticleContent)
  Fetcher --> App: ArticleContent

  App -> Engine: generate(article)
  note right of Engine
    load conversation.json
    (prompt config: intro, rules, schema)
  end note
  note right of Engine
    load topics.json
    (validator config: angles, rules)
  end note
  Engine -> Engine: build prompt from conversation.json + article text
  Engine -> Bedrock: complete(prompt)
  Bedrock --> Engine: JSON (summary + raw topics + factChecks)

  Engine -> Engine: parse JSON, extract raw topics
  Engine -> Validator: process(raw topics, topics.json config)
  Validator -> Validator: validate, score, order (up to 5)
  Validator --> Engine: validated topics
  Engine --> App: CompanionResult

  App -> Cache: save(result, for: url)
  App --> User: display summary (sheet)
end

@enduml
